# Gateway server
GATEWAY_PORT=8080
GIN_MODE=debug

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console

# Backend（后端业务服务）
BACKEND_URL=http://localhost:3000
INTERNAL_KEY=tokenfusion_internal_key
JWT_SECRET=tokenfusion_jwt_secret
JWT_ISSUER=tokenfusion
